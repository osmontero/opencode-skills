{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "threatwinds": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ThreatWinds",
      "options": {
        "baseURL": "https://apis.threatwinds.com/api/ai/v1"
      },
      "models": {
        "qwen-3.6": {
          "name": "Qwen 3.6",
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 262144,
            "input": 255144,
            "output": 7000
          },
          "options": {
            "temperature": 0.6,
            "topP": 0.95,
            "topK": 20,
            "minP": 0.0,
            "presencePenalty": 0.0,
            "repetitionPenalty": 1.0
          }
        },
        "qwen-3.6-pro": {
          "name": "Qwen 3.6 Pro",
          "attachment": true,
          "modalities": {
            "input": ["text", "image"],
            "output": ["text"]
          },
          "limit": {
            "context": 262144,
            "input": 255144,
            "output": 7000
          },
          "options": {
            "temperature": 1,
            "topP": 0.95,
            "topK": 20,
            "minP": 0.0,
            "presencePenalty": 0.0,
