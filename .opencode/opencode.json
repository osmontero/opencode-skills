{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "threatwinds": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "ThreatWinds",
      "options": {
        "baseURL": "https://apis.threatwinds.com/api/ai/v1"
      },
      "models": {
        "qwen-3.6": {
          "name": "Qwen 3.6",
          "limit": {
            "context": 262144,
            "input": 229376,
            "output": 15768
          },
          "options": {
            "temperature": 0.6,
            "topP": 0.95,
            "topK": 20,
            "minP": 0.0,
            "presencePenalty": 0.0,
            "repetitionPenalty": 1.0
          }
        },
        "qwen-3.6-pro": {
          "name": "Qwen 3.6 Pro",
          "limit": {
            "context": 262144,
            "input": 229376,
            "output": 15768
          },
          "options": {
            "temperature": 1,
            "topP": 0.95,
            "topK": 20,
            "minP": 0.0,
            "presencePenalty": 0.0,
            "repetitionPenalty": 1.0
          }
        },
        "silas-1.6": {
          "name": "Silas 1.6",
          "limit": {
            "context": 262144,
            "input": 229376,
            "output": 15768
          },
          "options": {
            "temperature": 0.6,
            "topP": 0.95,
            "topK": 20,
            "minP": 0.0,
            "presencePenalty": 0.0,
            "repetitionPenalty": 1.0
          }
        },
        "silas-1.6-pro": {
          "name": "Silas 1.6 Pro",
          "limit": {
            "context": 262144,
            "input": 229376,
            "output": 15768
          },
          "options": {
            "temperature": 1,
            "topP": 0.95,
            "topK": 20,
            "minP": 0.0,
            "presencePenalty": 0.0,
            "repetitionPenalty": 1.0
          }
        },
        "gpt-5": {
          "name": "GPT-5.4",
          "limit": {
            "context": 1178000,
            "input": 1050000,
            "output": 128000
          },
          "options": {
            "temperature": 1,
            "topP": 1,
            "presencePenalty": 0.0,
            "frequencyPenalty": 0.0
          }
        },
        "gpt-5-mini": {
          "name": "GPT-5 Mini",
          "limit": {
            "context": 528000,
            "input": 400000,
            "output": 64000
          },
          "options": {
            "temperature": 1,
            "topP": 1
          }
        },
        "claude-opus-4": {
          "name": "Claude Opus 4.6",
          "limit": {
            "context": 1128000,
            "input": 1000000,
            "output": 128000
          },
          "options": {
            "temperature": 1
          }
        },
        "claude-sonnet-4": {
          "name": "Claude Sonnet 4.6",
          "limit": {
            "context": 1064000,
            "input": 1000000,
            "output": 64000
          },
          "options": {
            "temperature": 1
          }
        }
      }
    }
  },
  "model": "threatwinds/qwen-3.6",
  "mcp": {
    "brave-search": {
      "enabled": true,
      "type": "local",
      "command": ["npx", "-y", "@brave/brave-search-mcp-server"],
      "environment": {
        "BRAVE_API_KEY": "{env:BRAVE_API_KEY}"
      }
    }
  },
  "lsp": {
    "gopls": {
      "command": ["gopls"],
      "extensions": [".go"]
    },
    "rust": {
      "command": ["rust-analyzer"],
      "extensions": [".rs"]
    },
    "dart": {
      "command": ["dart", "language-server", "--client-id=opencode"],
      "extensions": [".dart"]
    },
    "java": {
      "command": ["jdtls"],
      "extensions": [".java"]
    }
  },
  "agent": {
    "plan": {
      "prompt": "{file:./prompts/plan.txt}"
    },
    "build": {
      "prompt": "{file:./prompts/build.txt}"
    }
  }
}
